<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_asset_user" model="res.groups">
        <field name="name">Asset User</field>
        <field name="category_id" ref="base.module_category_administration"/>
    </record>

    <record id="group_asset_manager" model="res.groups">
        <field name="name">Asset Manager</field>
        <field name="category_id" ref="base.module_category_administration"/>
        <field name="implied_ids" eval="[(4, ref('group_asset_user'))]"/>
    </record>

    <record id="group_booking_user" model="res.groups">
        <field name="name">Booking User</field>
        <field name="category_id" ref="base.module_category_administration"/>
    </record>

    <record id="group_booking_manager" model="res.groups">
        <field name="name">Booking Manager</field>
        <field name="category_id" ref="base.module_category_administration"/>
        <field name="implied_ids" eval="[(4, ref('group_booking_user'))]"/>
    </record>

</odoo>
