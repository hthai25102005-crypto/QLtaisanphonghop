<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="booking_wizard_form"
            model="ir.ui.view">

        <field name="name">booking.wizard.form</field>

        <field name="model">booking.wizard</field>

        <field name="arch"
               type="xml">

            <form string="Đặt phòng nhanh">

                <group>

                    <field name="title"/>

                    <field name="employee_id"/>

                    <field name="room_id"/>

                    <field name="asset_id"/>

                    <field name="start_datetime"/>

                    <field name="end_datetime"/>

                    <field name="purpose"/>

                </group>

                <footer>

                    <button name="action_create_booking"
                            type="object"
                            string="Đặt phòng"
                            class="btn-primary"/>

                    <button string="Hủy"
                            special="cancel"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>