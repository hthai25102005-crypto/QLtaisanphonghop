<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="asset_meeting_root" name="Quản lý tài sản &amp; Phòng họp" sequence="1"/>

    <menuitem id="menu_dashboard" name="Dashboard" parent="asset_meeting_root" action="action_asset_dashboard" sequence="1"/>

    <menuitem id="menu_asset" name="Quản lý tài sản" parent="asset_meeting_root" sequence="10"/>

    <menuitem id="menu_category" name="Danh mục tài sản" parent="menu_asset" action="asset_category_action" sequence="1"/>
    <menuitem id="menu_asset_list" name="Danh sách tài sản" parent="menu_asset" action="asset_action" sequence="2"/>

    <menuitem id="menu_room" name="Phòng họp" parent="asset_meeting_root" action="meeting_room_action" sequence="20"/>
    <menuitem id="menu_booking" name="Đặt phòng" parent="asset_meeting_root" action="meeting_booking_action" sequence="30"/>

    <menuitem id="menu_history" name="Lịch sử sử dụng" parent="asset_meeting_root" action="asset_history_action" sequence="40"/>

    <!-- Charts submenu -->
    <menuitem id="menu_report" name="Báo cáo &amp; Thống kê" parent="asset_meeting_root" sequence="50"/>

    <menuitem id="menu_report_asset" name="Tài sản" parent="menu_report" action="action_report_asset" sequence="1"/>
    <menuitem id="menu_report_booking" name="Đặt phòng" parent="menu_report" action="action_report_booking" sequence="2"/>
    <menuitem id="menu_report_history" name="Lịch sử" parent="menu_report" action="action_report_history" sequence="3"/>

    <!-- Quick Booking Wizard -->
    <record id="booking_wizard_action" model="ir.actions.act_window">
        <field name="name">Đặt phòng nhanh</field>
        <field name="res_model">booking.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_booking_wizard" name="Đặt phòng nhanh" parent="asset_meeting_root" action="booking_wizard_action" sequence="5"/>

</odoo>
