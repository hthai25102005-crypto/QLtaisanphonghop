<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="meeting_booking_tree" model="ir.ui.view">
        <field name="name">meeting.booking.tree</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="title"/>
                <field name="employee_id"/>
                <field name="room_id"/>
                <field name="asset_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="duration"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="meeting_booking_form" model="ir.ui.view">
        <field name="name">meeting.booking.form</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Gửi duyệt" type="object" states="draft" class="oe_highlight"/>
                    <button name="action_approve" string="Duyệt" type="object" states="confirm" class="btn-primary"/>
                    <button name="action_done" string="Hoàn thành" type="object" states="approved"/>
                    <button name="action_cancel" string="Hủy" type="object" states="draft,confirm,approved"/>
                    <button name="action_reset" string="Reset" type="object" states="cancel"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="title"/>
                            <field name="employee_id"/>
                            <field name="department"/>
                        </group>
                        <group>
                            <field name="room_id"/>
                            <field name="asset_id"/>
                            <field name="participant"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                        <group>
                            <field name="duration" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mục đích">
                            <field name="purpose"/>
                        </page>
                        <page string="Ghi chú">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="meeting_booking_search" model="ir.ui.view">
        <field name="name">meeting.booking.search</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="employee_id"/>
                <field name="room_id"/>
                <field name="asset_id"/>
                <filter name="draft" string="Nháp" domain="[('state','=','draft')]"/>
                <filter name="confirm" string="Chờ duyệt" domain="[('state','=','confirm')]"/>
                <filter name="approved" string="Đã duyệt" domain="[('state','=','approved')]"/>
                <filter name="done" string="Hoàn thành" domain="[('state','=','done')]"/>
                <filter name="cancel" string="Đã hủy" domain="[('state','=','cancel')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_room" string="Phòng" context="{'group_by':'room_id'}"/>
                    <filter name="group_employee" string="Nhân viên" context="{'group_by':'employee_id'}"/>
                    <filter name="group_state" string="Trạng thái" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="meeting_booking_calendar" model="ir.ui.view">
        <field name="name">meeting.booking.calendar</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <calendar string="Lịch đặt phòng" date_start="start_datetime" date_stop="end_datetime" color="room_id">
                <field name="title"/>
                <field name="employee_id"/>
                <field name="room_id"/>
            </calendar>
        </field>
    </record>

    <record id="meeting_booking_action" model="ir.actions.act_window">
        <field name="name">Đặt phòng họp</field>
        <field name="res_model">meeting.booking</field>
        <field name="view_mode">calendar,tree,form</field>
    </record>

</odoo>
